{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": ["LOCALAPPDATA", "APPDATA", "GOPATH", "GOROOT", "GOCACHE", "HOME", "USERPROFILE"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"],
      "cache": false
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "lint": {},
    "clean": {
      "cache": false
    }
  }
}
